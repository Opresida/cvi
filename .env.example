# ============================================
# CVI Amazonas — Variáveis de Ambiente
# Copie para .env e preencha com seus valores
# ============================================

# Neon Database (PostgreSQL Serverless)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/cvi?sslmode=require

# JWT Secret (gere com: openssl rand -hex 32)
JWT_SECRET=seu_secret_aqui_mude_em_producao

# Porta do servidor backend
PORT=3001

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5000
